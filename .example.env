# Copy to .env and fill in values. Examples auto-load .env via godotenv.

# Foundry project endpoint, e.g. https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Foundry model name, e.g. gpt-5.4
FOUNDRY_MODEL_NAME=

# Azure Storage connection name, e.g. 
AZURE_STORAGE_CONNECTION_NAME=
