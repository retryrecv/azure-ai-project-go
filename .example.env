# Copy to .env and fill in values. Examples auto-load .env via godotenv.

# Foundry project endpoint, e.g. https://<account>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Optional: filter for examples that list deployments (e.g. OpenAI, Microsoft)
MODEL_PUBLISHER=

# Auth: examples use DefaultAzureCredential. Either run `az login`, or set:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
